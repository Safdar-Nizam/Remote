# Database
DATABASE_URL=postgresql+asyncpg://orchestrator:orchestrator_dev@localhost:5432/onboarding

# Queue backend: "memory" for local dev, "sqs" for production
QUEUE_BACKEND=memory

# Logging
LOG_LEVEL=DEBUG

# Admin API
ADMIN_API_KEY=dev-admin-key-change-me

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Remote
REMOTE_API_TOKEN=your-remote-api-token
REMOTE_API_BASE_URL=https://gateway.remote.com/v1

# Notion
NOTION_API_TOKEN=your-notion-integration-token
NOTION_LEGAL_DB_ID=your-notion-database-id

# Webhook Secrets (for verifying inbound webhooks)
KISSFLOW_WEBHOOK_SECRET=your-kissflow-secret
REMOTE_WEBHOOK_SECRET=your-remote-webhook-secret
